{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlurAutoClicker",
  "version": "3.4.1",
  "identifier": "BlurAutoClicker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run frontend:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BlurAutoClicker",
        "width": 500,
        "height": 150,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Blur009/Blur-AutoClicker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyREY0RTc2QTU4Qjc1N0UKUldSK2RZdWxkazdmSW1IQmI4ZVMwOTRzWnBiVENhMFNYMFRtN0V4R3N0Q2JXQUdqM2t4VnRnNUYK"
    },
    "windows": {
      "installMode": "passive"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"]
  }
}
